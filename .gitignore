# tools/: the app is fully native now (renderers cooked in, MK2 ROM pipeline
# removed), so only the BDB/BDD round-trip smoke test ships. Everything else is
# the author's local MK2 pipeline and stays on disk but untracked.
tools/*
!tools/roundtrip_smoke.py

# Removed MK2 tool sources kept locally for revisiting (not shipped)
/platform/_local/
